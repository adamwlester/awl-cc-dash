# Secrets and credentials
.env
*.key
credentials*.json

# Obsidian config (editor-specific, not project content)
.obsidian/

# Python virtual environments — repo-root .venv (per tests/run.ps1), any nested
# .venv (e.g. archive/mvp/.venv), and the <folder>-env name dev/tools/bootstrap-env.ps1
# creates (covers the legacy claude-code-sandbox-env too).
.venv/
venv/
*-env/
claude-code-sandbox-env/

# OS junk
Thumbs.db
Desktop.ini
.DS_Store

# Node
node_modules/

# Electron-vite build output (frontend/ and archive/mvp/frontend/)
out/

# Scratch — transient agent artifacts (screenshots, scratch HTML, debug dumps).
# Keep the folder discoverable, ignore its contents.
.scratch/*
!.scratch/.gitkeep

# Test run logs (timestamped, regenerated each run — keep the dir, not the logs)
**/tests/log/*
!**/tests/log/.gitkeep
# Pytest cache
.pytest_cache/

# Python bytecode
__pycache__/
*.pyc

# Image files
*.png
*.jpg
*.jpeg
*.gif
*.webp

# Dogfood store: runtime media assets stay out of git (state/ + docs/ are committed deliberately; asset bytes + their .meta.json sidecars are runtime data)
.awl-cc-dash/assets/

*.bmp
*.ico
*.tiff
*.tif

# Misc
.playwright-mcp/

# Agent memory — local/private agent memory should not be tracked
.claude/agent-memory-local/

# Session transcripts (personal exports) — root transcripts/ holds web/ (claude.ai via
# extract-web.py), desktop/ (desktop-app agent sessions via extract-desktop.py), and cli/
# (Claude Code CLI sessions via the claude-history-viewer extension). Never tracked.
# No-leading-slash pattern: this matches a `transcripts/` folder at ANY depth, not just this root one.
transcripts/

# Archive bucket for things kept on disk but intentionally NOT tracked in git
# (e.g. old personal session transcripts). The _ignored/ name signals "untracked".
archive/_ignored/

# Sidecar runtime state — live session records (tmux names + config) used to
# rebind to surviving tmux sessions after a sidecar restart. Operational state,
# never tracked.
sidecar/runtime/