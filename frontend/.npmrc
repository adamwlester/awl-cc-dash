# electron-vite@5 declares a conservative vite peer range (^5||^6||^7), but this
# project runs vite@8 + @vitejs/plugin-react@6, which coexist fine at runtime
# (the renderer rebuild #37 was verified headed on this exact set). npm 7+'s
# strict peer resolver rejects it without this flag, so pin it here so every
# `npm install` / `npm ci` (and start-dashboard.bat) resolves the proven set.
legacy-peer-deps=true
